      <column datatype='string' name='[CAFV Eligibility]' role='dimension' type='nominal' />
      <column caption='% CAFV' datatype='real' name='[Calculation_0229316618416128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [CAFV Eligibility] = &apos;Eligible&apos; THEN 1 ELSE 0 END) * 100/COUNT([VIN])' />
      </column>
      <column caption='Total EVs' datatype='integer' name='[Calculation_0229316640989185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Model Year] : COUNT([VIN]) }' />
      </column>
      <column caption='Total Count' datatype='integer' name='[Calculation_0229316655276034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Make] : COUNT([VIN]) }' />
      </column>
      <column caption='%BEV' datatype='real' name='[Calculation_0229316656672771]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM (IF [EV Type] = &apos;BEV&apos; THEN 1 ELSE 0 END) * 100/ COUNT([VIN])' />
